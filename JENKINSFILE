pipeline {
    // forcem que l'agent sigui linux amb flask i wiremock instal·lat
    agent { label 'linux && flask && wiremock'}
    // agent any
    stages {
        stage('Checkout') {
            steps {
                git 'https://github.com/daniunirdevops/helloworld.git'
            }
        }
        stage('Tests') {
            parallel {

                stage('Unit') {
                    steps {
                        catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                            sh '''
                                export PYTHONPATH=$WORKSPACE
                                python3 -m pytest test/unit --junitxml=result-unit.xml 
                            '''
                        }                
                    }
                }
                
                stage('Rest') {
                    steps {
                        
                        sh '''
        
                        export FLASK_APP=app/api.py
                        export FLASK_ENV=development
                            
                        python3 -m flask run --host=0.0.0.0 --port=5000 > flask.log 2>&1 &
                        FLASK_PID=$!
        
                        java -jar /opt/wiremock.jar --port 9090 --root-dir $WORKSPACE/test/wiremock > wiremock.log 2>&1 &
                        WIREMOCK_PID=$!
            
                        echo "Esperant Flask..."
                        timeout 30 sh -c 'until curl -s http://localhost:5000; do sleep 1; done'
            
                        echo "Esperant WireMock..."
                        timeout 30 sh -c 'until curl -s http://localhost:9090/calc/sqrt/64; do sleep 1; done'
                        
                        echo "Executant tests..."
                        python3 -m pytest test/rest --junitxml=result-rest.xml
        
                        kill $FLASK_PID
                        kill $WIREMOCK_PID                
                        '''
                    }
                }
            }   // parallel
        }            
       
        stage ('Results') {
            steps {
                junit 'result*.xml'
            }
        } 

    }
}
